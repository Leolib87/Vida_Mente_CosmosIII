---
interface Props {
  title: string;
  description?: string;
  lang?: string;
  htmlClass?: string;
  bodyClass?: string;
}

const { title, description, lang = "es", htmlClass, bodyClass } = Astro.props;
---

<!DOCTYPE html>
<html lang={lang} class={htmlClass}>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    {description && <meta name="description" content={description}>}
    <slot name="head" />
</head>
<body class={bodyClass}>
    <slot />
</body>
</html>
