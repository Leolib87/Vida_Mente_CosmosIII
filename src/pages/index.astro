---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout
  title="Vida, Mente y Cosmos | Archivo Transdisciplinario"
  description="Una exploración profunda: del origen entrópico del Cosmos, pasando por la Autopoiesis de la Vida, hasta la Fenomenología de la Mente."
  htmlClass="scroll-smooth"
  bodyClass="antialiased text-justify"
>
  <Fragment slot="head">
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@200;300;400;500;600;800;900&family=Merriweather:ital,wght@0,300;0,400;0,700;1,400&family=JetBrains+Mono:wght@300;400&display=swap" rel="stylesheet">

    <!-- Librerías Externas -->
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline src="https://unpkg.com/lucide@latest"></script>
    <script is:inline src="https://d3js.org/d3.v7.min.js"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>

    <!-- Configuración Tailwind (Colores Originales) -->
    <script is:inline>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        serif: ['Merriweather', 'serif'],
                        mono: ['JetBrains Mono', 'monospace'],
                    },
                    colors: {
                        cosmos: { 950: '#020617', 900: '#08080c', 800: '#11111a', 700: '#1a1a2e', 600: '#2a2a40' },
                        neon: { void: '#2d3436', blue: '#4f46e5', green: '#10b981', purple: '#a855f7', cyan: '#06b6d4', gold: '#fbbf24' },
                        amber: { DEFAULT: '#f59e0b', 500: '#f59e0b' },
                        slate: { 300: '#cbd5e1', 400: '#94a3b8' }
                    },
                    animation: {
                        'float': 'float 8s ease-in-out infinite',
                        'pulse-slow': 'pulse 6s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                        'spin-slow': 'spin 20s linear infinite',
                    },
                    keyframes: {
                        float: { '0%, 100%': { transform: 'translateY(0)' }, '50%': { transform: 'translateY(-15px)' } }
                    }
                }
            }
        }
    </script>

    <style is:global>
        :root { --nav-height: 80px; --amber: #f59e0b; --dark: #0f172a; }
        body { font-family: 'Inter', sans-serif; background-color: var(--dark); color: #cbd5e1; line-height: 1.8; overflow-x: hidden; margin: 0; padding: 0; background-image: radial-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px); background-size: 40px 40px; text-align: justify; }

        /* Scrollbar */
        ::-webkit-scrollbar { width: 10px; height: 10px; }
        ::-webkit-scrollbar-track { background: var(--dark); }
        ::-webkit-scrollbar-thumb { background: #334155; border-radius: 5px; border: 2px solid var(--dark); }
        ::-webkit-scrollbar-thumb:hover { background: var(--amber); }

        /* Navigation */
        nav { position: fixed; top: 0; left: 0; width: 100%; height: var(--nav-height); z-index: 110; transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); padding: 0 2rem; background: rgba(15, 23, 42, 0.6); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255, 255, 255, 0.05); }
        nav.scrolled { background: rgba(15, 23, 42, 0.95); box-shadow: 0 4px 30px rgba(0, 0, 0, 0.5); border-bottom: 1px solid rgba(245, 158, 11, 0.1); }

        /* Mega Menu */
        .mega-menu { position: fixed; top: var(--nav-height); left: 50%; transform: translateX(-50%) translateY(10px); width: min(98vw, 1700px); max-height: calc(100vh - var(--nav-height) - 20px); background: rgba(15, 23, 42, 0.98); backdrop-filter: blur(25px); border: 1px solid rgba(245, 158, 11, 0.2); border-radius: 0 0 1.5rem 1.5rem; padding: 2.5rem; opacity: 0; visibility: hidden; transition: all 0.3s ease; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.7); overflow-y: auto; z-index: 40; }
        .nav-item:hover .mega-menu { opacity: 1; visibility: visible; transform: translateX(-50%) translateY(0); }

        .mega-title { color: var(--amber); font-weight: 700; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.15em; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid rgba(245, 158, 11, 0.3); display: flex; align-items: center; gap: 0.5rem; }
        .menu-link { color: #94a3b8; text-decoration: none; font-size: 0.85rem; padding: 3px 0 3px 8px; border-radius: 4px; transition: all 0.2s; display: block; border-left: 2px solid transparent; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .menu-link:hover { color: white; background: rgba(255, 255, 255, 0.03); border-left: 2px solid var(--amber); padding-left: 12px; }

        /* Mobile Menu */
        .mobile-menu { position: fixed; inset: 0; background: var(--dark); z-index: 100; padding-top: var(--nav-height); transform: translateX(100%); transition: transform 0.4s ease; overflow-y: auto; }
        .mobile-menu.open { transform: translateX(0); }
        .accordion-content { max-height: 0; overflow: hidden; transition: max-height 0.4s ease-out; }
        .accordion-btn.active { color: var(--amber); }
        .accordion-btn.active svg { transform: rotate(180deg); }

        /* Helpers */
        .glass-card { background: rgba(17, 17, 26, 0.7); backdrop-filter: blur(16px); border: 1px solid rgba(255, 255, 255, 0.05); transition: all 0.5s ease; }
        .glass-card:hover { transform: translateY(-5px); background: rgba(26, 26, 46, 0.9); border-color: rgba(255, 255, 255, 0.1); box-shadow: 0 20px 50px -10px rgba(0, 0, 0, 0.5); }
        #bg-canvas { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; pointer-events: none; }
        .bg-gradient { position: fixed; inset: 0; z-index: -2; background: radial-gradient(circle at 30% 70%, rgba(245, 158, 11, 0.08) 0%, transparent 40%), radial-gradient(circle at 70% 20%, rgba(99, 102, 241, 0.08) 0%, transparent 40%), var(--dark); }
    </style>
  </Fragment>

