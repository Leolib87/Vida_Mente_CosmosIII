  <!-- LOGIC SCRIPT -->
  <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
          // 1. INIT ICONS
          lucide.createIcons();

          // 2. NAVBAR SCROLL EFFECT
          const nav = document.getElementById('navbar');
          window.addEventListener('scroll', () => {
              nav.classList.toggle('scrolled', window.scrollY > 20);
          });

          // 3. MOBILE MENU GENERATOR
          function initMobileMenuFromDesktop() {
              const desktopList = document.getElementById('desktop-menu-list');
              const mobileContainer = document.querySelector('.mobile-menu-content');
              const toggleBtn = document.getElementById('mobile-toggle');
              const mobileMenu = document.getElementById('mobile-menu');
              const iconMenu = document.getElementById('icon-menu');
              const iconClose = document.getElementById('icon-close');
              const body = document.body;

              if(!desktopList || !mobileContainer) return;

              mobileContainer.innerHTML = '';

              const items = desktopList.querySelectorAll('.nav-item');

              items.forEach(item => {
                  const title = item.getAttribute('data-title');

                  if(!title) {
                      const link = item.querySelector('a');
                      if(link) {
                          const clone = link.cloneNode(true);
                          clone.className = 'block py-4 border-b border-white/5 text-white font-bold uppercase tracking-widest text-sm flex items-center gap-3';
                          mobileContainer.appendChild(clone);
                      }
                      return;
                  }

                  const iconName = item.getAttribute('data-icon') || 'circle';

                  const group = document.createElement('div');
                  group.className = 'border-b border-white/5 py-4';

                  const btn = document.createElement('button');
                  btn.className = 'accordion-btn w-full flex justify-between items-center text-white font-bold uppercase tracking-widest text-sm';
                  btn.innerHTML = `
                      <div class="flex items-center gap-3">
                          <i data-lucide="${iconName}" class="text-amber-500 w-5 h-5"></i>
                          ${title}
                      </div>
                      <i data-lucide="chevron-down" class="w-4 h-4 text-amber-500 transition-transform duration-300"></i>
                  `;

                  const content = document.createElement('div');
                  content.className = 'accordion-content';

                  const innerList = document.createElement('div');
                  innerList.className = 'pl-8 pt-4 pb-2 space-y-6';

                  const megaMenu = item.querySelector('.mega-menu');
                  if(megaMenu) {
                      // Strategy: Iterate over immediate children columns of the grid
                      const gridColumns = megaMenu.firstElementChild.classList.contains('grid')
                           ? megaMenu.firstElementChild.children
                           : megaMenu.children;

                      Array.from(gridColumns).forEach(col => {

                         // CASO 1: Columna normal con H3
                         let header = col.querySelector('h3');

                         // Si hay H3 y NO hay detalles anidados (como en Humanidades)
                         if(header && !col.querySelector('summary')) {
                             const sectionContainer = document.createElement('div');
                             const mobileTitle = document.createElement('h4');
                             mobileTitle.className = 'text-amber-500 text-xs uppercase tracking-widest mb-3 font-bold border-b border-white/5 pb-1 w-max';
                             mobileTitle.textContent = header.textContent;
                             sectionContainer.appendChild(mobileTitle);

                             const links = col.querySelectorAll('ul a');
                             const ul = document.createElement('ul');
                             ul.className = 'space-y-2 border-l border-white/10 pl-3';
                             links.forEach(link => {
                                 const li = document.createElement('li');
                                 const mobileLink = link.cloneNode(true);
                                 mobileLink.className = 'block text-slate-400 hover:text-white text-sm transition-colors py-1';
                                 li.appendChild(mobileLink);
                                 ul.appendChild(li);
                             });
                             sectionContainer.appendChild(ul);
                             innerList.appendChild(sectionContainer);
                         }

                         // CASO 2: Columna con detalles anidados (Humanidades)
                         else {
                             // Buscar los summaries dentro de los details
                             const summaries = col.querySelectorAll('summary');
                             if(summaries.length > 0) {
                                 // Título Principal del bloque (H3)
                                 if(header) {
                                      const mainHeader = document.createElement('h4');
                                      mainHeader.className = 'text-amber-500 text-xs uppercase tracking-widest mb-4 font-bold w-max';
                                      mainHeader.textContent = header.textContent;
                                      innerList.appendChild(mainHeader);
                                 }

                                 summaries.forEach(summary => {
                                     const sectionContainer = document.createElement('div');
                                     sectionContainer.className = "mb-4"; // Espaciado entre grupos

                                     const mobileTitle = document.createElement('h5');
                                     // Limpiamos el texto del summary (quitamos la flecha ▼ si existe en texto)
                                     mobileTitle.className = 'text-neon-cyan text-xs uppercase tracking-widest mb-2 font-bold border-b border-white/10 pb-1 w-full';
                                     mobileTitle.textContent = summary.innerText.replace('▼', '').trim();
                                     sectionContainer.appendChild(mobileTitle);

                                     // Encontrar el UL hermano del summary
                                     const parentDetails = summary.parentElement;
                                     const links = parentDetails.querySelectorAll('ul a');

                                     const ul = document.createElement('ul');
                                     ul.className = 'space-y-2 border-l border-neon-cyan/20 pl-3';

                                     links.forEach(link => {
                                         const li = document.createElement('li');
                                         const mobileLink = link.cloneNode(true);
                                         mobileLink.className = 'block text-slate-400 hover:text-white text-sm transition-colors py-1';
                                         li.appendChild(mobileLink);
                                         ul.appendChild(li);
                                     });
                                     sectionContainer.appendChild(ul);
                                     innerList.appendChild(sectionContainer);
                                 });
                             }
                         }
                      });
                  }

                  content.appendChild(innerList);
                  group.appendChild(btn);
                  group.appendChild(content);
                  mobileContainer.appendChild(group);

                  btn.addEventListener('click', () => {
                      const isOpen = btn.classList.contains('active');
                      document.querySelectorAll('.accordion-btn').forEach(b => {
                          b.classList.remove('active');
                          b.nextElementSibling.style.maxHeight = null;
                      });
                      if(!isOpen) {
                          btn.classList.add('active');
                          content.style.maxHeight = content.scrollHeight + "px";
                      }
                  });
              });

              toggleBtn.addEventListener('click', () => {
                  const isOpen = mobileMenu.classList.contains('open');
                  mobileMenu.classList.toggle('open');
                  iconMenu.classList.toggle('hidden');
                  iconClose.classList.toggle('hidden');
                  body.style.overflow = isOpen ? '' : 'hidden';
              });

              lucide.createIcons();
          }

          initMobileMenuFromDesktop();

          // 4. THREE.JS BACKGROUND
          const initThree = () => {
              const canvas = document.getElementById('bg-canvas');
              if(!canvas) return;
              const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
              renderer.setSize(window.innerWidth, window.innerHeight);
              renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

              const scene = new THREE.Scene();
              const camera = new THREE.PerspectiveCamera(75, window.innerWidth/window.innerHeight, 0.1, 1000);
              camera.position.z = 30;

              const particlesCount = window.innerWidth < 768 ? 800 : 2000;
              const posArray = new Float32Array(particlesCount * 3);
              for(let i=0; i<particlesCount*3; i++) posArray[i] = (Math.random()-0.5)*100;

              const material = new THREE.PointsMaterial({ size: 0.15, color: 0xf59e0b, transparent: true, opacity: 0.6 });
              const mesh = new THREE.Points(new THREE.BufferGeometry().setAttribute('position', new THREE.BufferAttribute(posArray, 3)), material);
              scene.add(mesh);

              const animate = () => {
                  requestAnimationFrame(animate);
                  mesh.rotation.y += 0.0003;
                  mesh.rotation.x += 0.0001;
                  renderer.render(scene, camera);
              };
              animate();

              window.addEventListener('resize', () => {
                  camera.aspect = window.innerWidth/window.innerHeight;
                  camera.updateProjectionMatrix();
                  renderer.setSize(window.innerWidth, window.innerHeight);
              });
          };
          initThree();

          // 5. D3 VISUALIZATION
          const initD3 = () => {
              const container = document.getElementById('visualization');
              if(!container) return;

              const width = container.clientWidth;
              const height = container.clientHeight;
              const svg = d3.select("#visualization").append("svg").attr("width", "100%").attr("height", "100%").attr("viewBox", [0, 0, width, height]);

              const nodes = [
                  {id:"Cosmos", group:1}, {id:"Vida", group:1}, {id:"Mente", group:1},
                  {id:"Entropia", group:2}, {id:"Autopoiesis", group:2}, {id:"Enaccion", group:2},
                  {id:"Varela", group:3}, {id:"Maturana", group:3}, {id:"Levin", group:3}
              ];
              const links = [
                  {source:"Cosmos", target:"Vida"}, {source:"Vida", target:"Mente"},
                  {source:"Cosmos", target:"Entropia"}, {source:"Vida", target:"Autopoiesis"},
                  {source:"Mente", target:"Enaccion"}, {source:"Autopoiesis", target:"Varela"},
                  {source:"Autopoiesis", target:"Maturana"}, {source:"Vida", target:"Levin"}
              ];

              const simulation = d3.forceSimulation(nodes)
                  .force("link", d3.forceLink(links).id(d => d.id).distance(80))
                  .force("charge", d3.forceManyBody().strength(-200))
                  .force("center", d3.forceCenter(width/2, height/2));

              const link = svg.append("g").selectAll("line").data(links).join("line").attr("stroke", "#475569").attr("stroke-width", 1);
              const node = svg.append("g").selectAll("circle").data(nodes).join("circle").attr("r", 5).attr("fill", "#f59e0b");
              const label = svg.append("g").selectAll("text").data(nodes).join("text").text(d => d.id).attr("x", 8).attr("y", 3).attr("fill", "#fff").style("font-size", "10px").style("font-family", "monospace");

              simulation.on("tick", () => {
                  link.attr("x1", d => d.source.x).attr("y1", d => d.source.y).attr("x2", d => d.target.x).attr("y2", d => d.target.y);
                  node.attr("cx", d => d.x).attr("cy", d => d.y);
                  label.attr("x", d => d.x + 8).attr("y", d => d.y + 3);
              });
          };
          initD3();
      });
  </script>
</BaseLayout>
