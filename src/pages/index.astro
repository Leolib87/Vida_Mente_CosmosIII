---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteNav from "../components/SiteNav.astro";
---
<BaseLayout
  title="Vida, Mente y Cosmos | Archivo Transdisciplinario"
  description="Una exploración profunda: del origen entrópico del Cosmos, pasando por la Autopoiesis de la Vida, hasta la Fenomenología de la Mente."
  htmlClass="scroll-smooth"
  bodyClass="antialiased text-justify"
>
  <Fragment slot="head">
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@200;300;400;500;600;800;900&family=Merriweather:ital,wght@0,300;0,400;0,700;1,400&family=JetBrains+Mono:wght@300;400&display=swap" rel="stylesheet">

    <!-- Librerías Externas -->
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline src="https://unpkg.com/lucide@latest"></script>
    <script is:inline src="https://d3js.org/d3.v7.min.js"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>

    <!-- Configuración Tailwind (Colores Originales) -->
    <script is:inline>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        serif: ['Merriweather', 'serif'],
                        mono: ['JetBrains Mono', 'monospace'],
                    },
                    colors: {
                        cosmos: { 950: '#020617', 900: '#08080c', 800: '#11111a', 700: '#1a1a2e', 600: '#2a2a40' },
                        neon: { void: '#2d3436', blue: '#4f46e5', green: '#10b981', purple: '#a855f7', cyan: '#06b6d4', gold: '#fbbf24' },
                        amber: { DEFAULT: '#f59e0b', 500: '#f59e0b' },
                        slate: { 300: '#cbd5e1', 400: '#94a3b8' }
                    },
                    animation: {
                        'float': 'float 8s ease-in-out infinite',
                        'pulse-slow': 'pulse 6s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                        'spin-slow': 'spin 20s linear infinite',
                    },
                    keyframes: {
                        float: { '0%, 100%': { transform: 'translateY(0)' }, '50%': { transform: 'translateY(-15px)' } }
                    }
                }
            }
        }
    </script>

    <style is:global>
        :root { --nav-height: 80px; --amber: #f59e0b; --dark: #0f172a; }
        body { font-family: 'Inter', sans-serif; background-color: var(--dark); color: #cbd5e1; line-height: 1.8; overflow-x: hidden; margin: 0; padding: 0; background-image: radial-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px); background-size: 40px 40px; text-align: justify; }

        /* Scrollbar */
        ::-webkit-scrollbar { width: 10px; height: 10px; }
        ::-webkit-scrollbar-track { background: var(--dark); }
        ::-webkit-scrollbar-thumb { background: #334155; border-radius: 5px; border: 2px solid var(--dark); }
        ::-webkit-scrollbar-thumb:hover { background: var(--amber); }

        /* Helpers */
        .glass-card { background: rgba(17, 17, 26, 0.7); backdrop-filter: blur(16px); border: 1px solid rgba(255, 255, 255, 0.05); transition: all 0.5s ease; }
        .glass-card:hover { transform: translateY(-5px); background: rgba(26, 26, 46, 0.9); border-color: rgba(255, 255, 255, 0.1); box-shadow: 0 20px 50px -10px rgba(0, 0, 0, 0.5); }
        #bg-canvas { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; pointer-events: none; }
        .bg-gradient { position: fixed; inset: 0; z-index: -2; background: radial-gradient(circle at 30% 70%, rgba(245, 158, 11, 0.08) 0%, transparent 40%), radial-gradient(circle at 70% 20%, rgba(99, 102, 241, 0.08) 0%, transparent 40%), var(--dark); }
    </style>
  </Fragment>

  <div class="bg-gradient"></div>
  <canvas id="bg-canvas"></canvas>

  <SiteNav />


  <!-- MAIN CONTENT -->
  <main class="relative z-10 pt-[80px]">

      <!-- HERO -->
      <section id="inicio" class="relative min-h-[90vh] flex flex-col items-center justify-center text-center overflow-hidden">
          <div class="relative z-10 px-4">

              <!-- Badge de Estado Simple -->
              <div class="animate-float mb-8">
                  <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-white/10 bg-white/5 backdrop-blur-sm mb-6 shadow-glow mx-auto">
                      <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
                      <span class="text-[10px] font-mono text-slate-300 tracking-widest uppercase">Sistema v3.0 :: OnLine</span>
                  </div>

                  <!-- Título GRIS como solicitado -->
                  <h1 class="text-5xl md:text-8xl lg:text-9xl font-black tracking-tighter mb-4 text-gray-500 leading-none drop-shadow-2xl">
                      COSMOS<br>
                      <span class="italic font-serif">VIDA</span><br>
                      <span>MENTE</span>
                  </h1>
              </div>

              <a href="#manifiesto" class="inline-flex items-center gap-2 px-8 py-4 bg-white/10 hover:bg-white/20 backdrop-blur-md border border-white/20 text-white font-bold text-sm tracking-widest uppercase hover:pr-12 transition-all duration-300 group relative overflow-hidden rounded-full">
                  <span class="relative z-10">Explorar Archivo</span>
                  <i data-lucide="arrow-right" class="absolute right-4 opacity-0 group-hover:opacity-100 transition-all text-amber-500"></i>
              </a>
          </div>

          <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce text-slate-500 flex flex-col items-center">
              <span class="text-[10px] font-mono tracking-widest uppercase mb-2">Desplazar</span>
              <i data-lucide="chevrons-down" class="w-5 h-5"></i>
          </div>
      </section>

      <!-- MANIFIESTO -->
      <section id="manifiesto" class="py-32 bg-cosmos-950 relative border-t border-white/5">
          <div class="max-w-7xl mx-auto px-6">
              <!-- Contenido previo mantenido... -->
              <div class="text-center mb-24">
                  <h2 class="text-xs font-mono text-neon-blue tracking-[0.3em] uppercase mb-4">Ontología del Sistema</h2>
                  <h3 class="text-4xl md:text-5xl font-serif text-white italic">Manifiesto Transdisciplinario</h3>
              </div>

              <!-- Section I: Cosmos -->
              <article class="grid md:grid-cols-2 gap-16 items-center mb-32 group">
                  <div>
                      <div class="flex items-center gap-3 mb-6">
                          <i data-lucide="orbit" class="text-neon-blue w-6 h-6"></i>
                          <h4 class="text-2xl font-bold text-white tracking-wide uppercase">I. El Cosmos</h4>
                      </div>
                      <h5 class="text-lg text-neon-blue font-serif italic mb-6">"El cuerpo de Dios en descomposición"</h5>
                      <p class="text-slate-400 leading-loose mb-6">
                          Todo emerge en el silencio de la física. Exploramos el universo no como un mero contenedor, sino como un <strong class="text-white">proceso termodinámico</strong> irreversible. Desde la metafísica de Mainländer hasta la entropía computacional.
                      </p>
                  </div>
                  <div class="glass-card h-64 relative rounded-lg overflow-hidden flex items-center justify-center p-6">
                      <div class="grid grid-cols-12 gap-1 opacity-40 animate-pulse-slow w-full h-full">
                          <script is:inline>for(let i=0; i<48; i++) document.write(`<div class="w-1 h-1 rounded-full ${Math.random() > 0.5 ? 'bg-neon-blue' : 'bg-transparent'}"></div>`);</script>
                      </div>
                      <div class="absolute bottom-4 right-4 text-[10px] font-mono text-neon-blue">> EXEC: ENTROPY.PY</div>
                  </div>
              </article>

              <!-- Section II: Vida -->
              <article class="grid md:grid-cols-2 gap-16 items-center mb-32 md:flex-row-reverse group">
                  <div class="md:order-2">
                      <div class="flex items-center gap-3 mb-6">
                          <i data-lucide="dna" class="text-neon-green w-6 h-6"></i>
                          <h4 class="text-2xl font-bold text-white tracking-wide uppercase">II. La Vida</h4>
                      </div>
                      <h5 class="text-lg text-neon-green font-serif italic mb-6">"Precaria por definición"</h5>
                      <p class="text-slate-400 leading-loose mb-6">
                          Sobre el sustrato inerte ocurre el milagro de la precariedad. La pregunta central: <strong class="text-white">¿Qué separa a la Máquina del Ser Vivo?</strong> A través de la Autopoiesis, entendemos la vida como autoproducción.
                      </p>
                  </div>
                  <div class="md:order-1 glass-card h-64 relative rounded-lg overflow-hidden flex items-center justify-center">
                      <div class="w-32 h-32 border border-neon-green/30 rounded-full flex items-center justify-center animate-[spin-slow_15s_linear_infinite]">
                          <div class="w-24 h-24 border border-neon-green/60 rounded-full"></div>
                          <div class="absolute top-0 w-2 h-2 bg-neon-green rounded-full shadow-[0_0_10px_#10b981]"></div>
                      </div>
                      <div class="absolute bottom-4 left-4 text-[10px] font-mono text-neon-green">> STATUS: AUTOPOIESIS</div>
                  </div>
              </article>

              <!-- Section III: Mente -->
              <article class="grid md:grid-cols-2 gap-16 items-center group">
                  <div>
                      <div class="flex items-center gap-3 mb-6">
                          <i data-lucide="brain-circuit" class="text-neon-purple w-6 h-6"></i>
                          <h4 class="text-2xl font-bold text-white tracking-wide uppercase">III. La Mente</h4>
                      </div>
                      <h5 class="text-lg text-neon-purple font-serif italic mb-6">"No está en la cabeza"</h5>
                      <p class="text-slate-400 leading-loose mb-6">
                          La mente es <strong class="text-white">Encarnada, Extendida y Enactiva (4E)</strong>. Rechazamos el solipsismo. Aquí la ciencia dura dialoga con las ficciones de Borges, entendiendo que pensar es navegar la incertidumbre.
                      </p>
                  </div>
                  <div class="glass-card h-64 relative rounded-lg overflow-hidden flex items-center justify-center">
                      <svg class="w-full h-full opacity-50" viewBox="0 0 100 100">
                          <circle cx="20" cy="50" r="2" fill="#a855f7" class="animate-pulse"><animate attributeName="opacity" values="0.5;1;0.5" dur="2s" repeatCount="indefinite"/></circle>
                          <circle cx="80" cy="50" r="2" fill="#a855f7" class="animate-pulse"><animate attributeName="opacity" values="0.5;1;0.5" dur="2s" begin="1s" repeatCount="indefinite"/></circle>
                          <line x1="20" y1="50" x2="80" y2="50" stroke="#a855f7" stroke-width="0.5" stroke-dasharray="2 2" />
                      </svg>
                      <div class="absolute bottom-4 right-4 text-[10px] font-mono text-neon-purple">> CONTEXT: ENACTION</div>
                  </div>
              </article>
          </div>
      </section>

      <!-- CARTOGRAFIA VISUAL -->
      <section class="py-24 bg-black border-t border-white/5">
          <div class="max-w-[95%] mx-auto px-4">
              <h2 class="text-xs font-mono text-slate-500 tracking-[0.2em] uppercase mb-8">Cartografía Visual</h2>
              <div id="visualization" class="w-full h-[60vh] min-h-[400px] glass-card rounded-xl overflow-hidden relative"></div>
          </div>
      </section>

      <!-- LABORATORIO & TERMINAL DETALLADO -->
      <section class="py-24 bg-cosmos-900 border-t border-white/5">
          <div class="max-w-7xl mx-auto px-6">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">

                  <!-- Text Info -->
                  <div>
                      <h2 class="text-3xl font-bold text-white font-serif italic mb-6">La Praxis del Conocimiento</h2>
                      <p class="text-slate-400 leading-relaxed mb-8">
                          El conocimiento no es solo teoría; es herramienta. Este laboratorio digital ofrece utilidades desarrolladas para acelerar el trabajo científico, desde la biología húmeda hasta el análisis de datos masivos.
                      </p>
                      <div class="grid gap-4">
                          <div class="flex items-start gap-4 p-4 glass-card rounded-lg">
                              <i data-lucide="cpu" class="text-neon-cyan w-6 h-6 mt-1"></i>
                              <div>
                                  <h4 class="text-white font-bold text-sm uppercase">Automatización</h4>
                                  <p class="text-xs text-slate-500 mt-1">Calculadoras de laboratorio y scripts de Python para biología.</p>
                              </div>
                          </div>
                          <div class="flex items-start gap-4 p-4 glass-card rounded-lg">
                              <i data-lucide="bot" class="text-neon-purple w-6 h-6 mt-1"></i>
                              <div>
                                  <h4 class="text-white font-bold text-sm uppercase">Inteligencia Artificial</h4>
                                  <p class="text-xs text-slate-500 mt-1">Agentes autónomos, LLMs y asistentes de investigación.</p>
                              </div>
                          </div>
                      </div>
                  </div>

                  <!-- Abstract Terminal UI (Full Version) -->
                  <div class="bg-[#0a0a0f] border border-gray-800 rounded-lg p-6 font-mono text-xs shadow-2xl relative overflow-hidden group hover:border-amber-500/30 transition-colors">
                      <!-- Header -->
                      <div class="flex items-center justify-between mb-4 border-b border-gray-800 pb-2">
                          <div class="flex gap-2">
                              <div class="w-3 h-3 rounded-full bg-red-500"></div>
                              <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                              <div class="w-3 h-3 rounded-full bg-green-500"></div>
                          </div>
                          <span class="text-slate-600">leolib_terminal.sh</span>
                      </div>
                      <!-- Body -->
                      <div class="space-y-3 text-slate-300">
                          <p>> <span class="text-neon-blue">load</span> module --biology --context=autopoiesis</p>
                          <p class="text-slate-500">[INFO] Initializing Biocell experiments...</p>
                          <p class="text-slate-500">[INFO] Parsing DNA_extraction.html...</p>

                          <p>> <span class="text-neon-purple">query</span> --db="Fondecyt_2025" --filter="Education"</p>
                          <div class="h-1 w-full bg-gray-800 rounded overflow-hidden my-2">
                              <div class="h-full bg-gradient-to-r from-neon-blue to-neon-purple w-[75%] animate-pulse"></div>
                          </div>
                          <p class="text-neon-green">✓ Found 128 matching projects.</p>

                          <p>> <span class="text-neon-cyan">run</span> simulation --model="GameOfLife3D"</p>
                          <p class="text-slate-500">[INFO] Rendering WebGL Context...</p>
                          <p class="animate-pulse text-amber-500">_</p>
                      </div>
                      <!-- Background Glow -->
                      <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-neon-blue/10 rounded-full blur-3xl pointer-events-none"></div>
                  </div>

              </div>
          </div>
      </section>

  </main>

  <!-- FOOTER -->
  <footer id="contacto" class="bg-black border-t border-white/10 pt-16 pb-8">
      <div class="max-w-7xl mx-auto px-6">
          <div class="grid md:grid-cols-3 gap-12 mb-12">
              <div>
                  <div class="flex items-center gap-2 mb-4 text-white">
                      <i data-lucide="infinity" class="w-5 h-5"></i>
                      <span class="font-bold tracking-widest text-sm">O.C.V.M.</span>
                  </div>
                  <p class="text-slate-600 text-xs leading-relaxed max-w-xs">
                      Este archivo es un organismo vivo. Evoluciona con cada nueva lectura, experimento y reflexión.
                  </p>
              </div>
              <div>
                  <h4 class="text-white font-bold text-xs uppercase tracking-widest mb-4">Enlaces</h4>
                  <ul class="space-y-2 text-xs text-slate-500">
                      <li><a href="https://github.com/Leolib87" class="hover:text-white transition-colors">GitHub</a></li>
                      <li><a href="#" class="hover:text-white transition-colors">News</a></li>
                  </ul>
              </div>
              <div>
                  <h4 class="text-white font-bold text-xs uppercase tracking-widest mb-4">Contacto</h4>
                  <a href="mailto:contacto@ejemplo.com" class="text-xs text-slate-500 hover:text-white transition-colors flex items-center gap-2">
                      <i data-lucide="mail" class="w-3 h-3"></i> Enviar correspondencia
                  </a>
              </div>
          </div>
          <div class="border-t border-white/5 pt-8 text-center">
              <p class="text-[10px] text-slate-700 font-mono">© 2026 VIDA, MENTE Y COSMOS. DISEÑADO EN EL ETERNO RETORNO.</p>
          </div>
      </div>
  </footer>

  <!-- LOGIC SCRIPT -->
  <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
          // 4. THREE.JS BACKGROUND
          const initThree = () => {
              const canvas = document.getElementById('bg-canvas');
              if(!canvas) return;
              const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
              renderer.setSize(window.innerWidth, window.innerHeight);
              renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

              const scene = new THREE.Scene();
              const camera = new THREE.PerspectiveCamera(75, window.innerWidth/window.innerHeight, 0.1, 1000);
              camera.position.z = 30;

              const particlesCount = window.innerWidth < 768 ? 800 : 2000;
              const posArray = new Float32Array(particlesCount * 3);
              for(let i=0; i<particlesCount*3; i++) posArray[i] = (Math.random()-0.5)*100;

              const material = new THREE.PointsMaterial({ size: 0.15, color: 0xf59e0b, transparent: true, opacity: 0.6 });
              const mesh = new THREE.Points(new THREE.BufferGeometry().setAttribute('position', new THREE.BufferAttribute(posArray, 3)), material);
              scene.add(mesh);

              const animate = () => {
                  requestAnimationFrame(animate);
                  mesh.rotation.y += 0.0003;
                  mesh.rotation.x += 0.0001;
                  renderer.render(scene, camera);
              };
              animate();

              window.addEventListener('resize', () => {
                  camera.aspect = window.innerWidth/window.innerHeight;
                  camera.updateProjectionMatrix();
                  renderer.setSize(window.innerWidth, window.innerHeight);
              });
          };
          initThree();

          // 5. D3 VISUALIZATION
          const initD3 = () => {
              const container = document.getElementById('visualization');
              if(!container) return;

              const width = container.clientWidth;
              const height = container.clientHeight;
              const svg = d3.select("#visualization").append("svg").attr("width", "100%").attr("height", "100%").attr("viewBox", [0, 0, width, height]);

              const nodes = [
                  {id:"Cosmos", group:1}, {id:"Vida", group:1}, {id:"Mente", group:1},
                  {id:"Entropia", group:2}, {id:"Autopoiesis", group:2}, {id:"Enaccion", group:2},
                  {id:"Varela", group:3}, {id:"Maturana", group:3}, {id:"Levin", group:3}
              ];
              const links = [
                  {source:"Cosmos", target:"Vida"}, {source:"Vida", target:"Mente"},
                  {source:"Cosmos", target:"Entropia"}, {source:"Vida", target:"Autopoiesis"},
                  {source:"Mente", target:"Enaccion"}, {source:"Autopoiesis", target:"Varela"},
                  {source:"Autopoiesis", target:"Maturana"}, {source:"Vida", target:"Levin"}
              ];

              const simulation = d3.forceSimulation(nodes)
                  .force("link", d3.forceLink(links).id(d => d.id).distance(80))
                  .force("charge", d3.forceManyBody().strength(-200))
                  .force("center", d3.forceCenter(width/2, height/2));

              const link = svg.append("g").selectAll("line").data(links).join("line").attr("stroke", "#475569").attr("stroke-width", 1);
              const node = svg.append("g").selectAll("circle").data(nodes).join("circle").attr("r", 5).attr("fill", "#f59e0b");
              const label = svg.append("g").selectAll("text").data(nodes).join("text").text(d => d.id).attr("x", 8).attr("y", 3).attr("fill", "#fff").style("font-size", "10px").style("font-family", "monospace");

              simulation.on("tick", () => {
                  link.attr("x1", d => d.source.x).attr("y1", d => d.source.y).attr("x2", d => d.target.x).attr("y2", d => d.target.y);
                  node.attr("cx", d => d.x).attr("cy", d => d.y);
                  label.attr("x", d => d.x + 8).attr("y", d => d.y + 3);
              });
          };
          initD3();
      });
  </script>
</BaseLayout>
