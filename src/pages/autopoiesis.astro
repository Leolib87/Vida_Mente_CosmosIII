---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteNav from "../components/SiteNav.astro";
---
<BaseLayout
  title="Simulación de Autopoiesis | O.C.V.M."
  lang="es"
  bodyClass="selection:bg-amber-500 selection:text-slate-900 min-h-screen flex flex-col overflow-x-hidden"
>
  <Fragment slot="head">

    <!-- D3.js is required for the simulation logic -->
    <script is:inline src="https://d3js.org/d3.v7.min.js"></script>
    <!-- Lucide: requerido por el nav compartido (SiteNav) -->
    <style is:global>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;800&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap');

        body {
            font-family: 'Inter', sans-serif;
            background-color: #020617; /* slate-950 */
            color: #94a3b8; /* slate-400 */
            scroll-behavior: smooth;
            background-image: radial-gradient(circle at 50% 0%, #1e293b 0%, #020617 70%);
            background-attachment: fixed;
        }

        .font-serif {
            font-family: 'Playfair Display', serif;
        }

        /* Ajustes scrollbar */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #020617; }
        ::-webkit-scrollbar-thumb { background: #334155; border-radius: 4px; }

        /* Estilos específicos para la Simulación D3 */
        #visualization {
            background: rgba(2, 6, 23, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.05);
            box-shadow: inset 0 0 20px rgba(0,0,0,0.5);
        }
        /* Colores de los nodos en la simulación */
        .circle-substrate { fill: #38bdf8; /* sky-400 */ opacity: 0.6; }
        .circle-enzyme { fill: #f59e0b; /* amber-500 */ }
        .circle-link { fill: #e2e8f0; /* slate-200 */ }

        input[type=range] {
            accent-color: #f59e0b;
        }

        /* --- NUEVO ESTILO DE CITAS --- */
        .citation-modern {
            position: relative;
            background-color: #0f172a; /* Slate 900 sólido para contraste nítido */
            border-left: 4px solid #f59e0b; /* Borde Ámbar */
            padding: 2rem;
            margin: 3rem 0;
            border-radius: 0 0.5rem 0.5rem 0;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
            font-family: 'Playfair Display', serif;
            font-size: 1.1rem;
            line-height: 1.8;
            color: #e2e8f0; /* Texto claro */
            transition: transform 0.3s ease;
        }

        .citation-modern:hover {
            transform: translateX(5px);
        }

        .citation-modern::before {
            content: '"';
            position: absolute;
            top: -1.5rem;
            left: 1rem;
            font-size: 5rem;
            line-height: 1;
            color: #f59e0b;
            opacity: 0.2;
            font-family: serif;
        }

        .citation-source {
            display: block;
            margin-top: 1rem;
            font-family: 'Inter', sans-serif;
            font-size: 0.75rem;
            font-weight: 600;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            text-align: right;
        }

        /* Clases de utilidad para simulación en texto */
        .sim-text-substrate { color: #38bdf8; font-weight: 600; }
        .sim-text-enzyme { color: #f59e0b; font-weight: 600; }
        .sim-text-link { color: #e2e8f0; font-weight: 600; }

        .concept-card {
            background: rgba(30, 41, 59, 0.4);
            border: 1px solid rgba(255,255,255,0.05);
            padding: 1.5rem;
            border-radius: 0.5rem;
            transition: all 0.3s;
        }
        .concept-card:hover {
            background: rgba(30, 41, 59, 0.6);
            border-color: rgba(56, 189, 248, 0.3); /* Sky blue hint */
        }
    </style>
  </Fragment>

  <SiteNav />

    <!-- Contenido Principal -->
    <div class="flex-grow pt-32 md:pt-48 pb-16 md:pb-24 px-6 md:px-12 w-full">
        <main class="w-full mx-auto text-center">

            <!-- Bloque Hero -->
            <header class="mb-24 relative animate-fade-in-up">
                <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] h-[300px] md:w-[600px] md:h-[600px] bg-amber-500/5 rounded-full blur-3xl -z-10"></div>

                <h1 class="text-4xl sm:text-5xl md:text-7xl font-black text-slate-100 mb-6 leading-none tracking-tighter drop-shadow-2xl break-words">
                    AUTOPOIESIS<br>
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-slate-100 to-slate-500 text-2xl md:text-4xl block mt-4 font-serif italic">La organización de lo vivo</span>
                </h1>

                <p class="mt-8 text-sm md:text-base text-slate-400 font-medium tracking-wide max-w-2xl mx-auto">
                    Un análisis interactivo basado en el paper fundacional de <strong>Varela, Maturana y Uribe (1974)</strong> que redefine la biología al separar la historia evolutiva de la organización individual.
                </p>

                <div class="mt-16 flex justify-center">
                    <div class="h-24 w-px bg-gradient-to-b from-amber-500/0 via-amber-500/50 to-amber-500/0"></div>
                </div>
            </header>

            <!-- Sección de Simulación -->
            <section id="simulacion" class="w-full mx-auto mb-24 text-left bg-slate-900/40 p-6 md:p-8 rounded-xl border border-white/5 shadow-xl backdrop-blur-sm">
                <div class="flex flex-col md:flex-row justify-between items-center mb-6 border-b border-slate-800 pb-4">
                    <h3 class="text-amber-500 font-bold uppercase tracking-widest text-xs">Simulación en Tiempo Real: Teselado Autopoiético</h3>
                    <p class="text-[10px] text-slate-500 mt-2 md:mt-0 font-mono" id="status">Iniciando sistema...</p>
                </div>

                <!-- Controles -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6 mb-8 text-xs font-medium text-slate-400">
                    <div class="bg-slate-950/50 p-3 rounded-lg border border-white/5">
                        <label for="substrateDensity" class="block mb-2 text-slate-200">Densidad Sustrato <span class="sim-text-substrate">(O)</span>: <span id="substrateDensityValue" class="text-white">50</span>%</label>
                        <input type="range" id="substrateDensity" min="10" max="70" value="50" class="w-full h-1 bg-slate-700 rounded-lg appearance-none cursor-pointer">
                    </div>
                    <div class="bg-slate-950/50 p-3 rounded-lg border border-white/5">
                        <label for="enzymeCount" class="block mb-2 text-slate-200">Enzimas <span class="sim-text-enzyme">(*)</span>: <span id="enzymeCountValue" class="text-white">20</span></label>
                        <input type="range" id="enzymeCount" min="1" max="100" value="20" class="w-full h-1 bg-slate-700 rounded-lg appearance-none cursor-pointer">
                    </div>
                    <div class="bg-slate-950/50 p-3 rounded-lg border border-white/5">
                        <label for="substrateSpeed" class="block mb-2 text-slate-200">Velocidad: <span id="substrateSpeedValue" class="text-white">10</span></label>
                        <input type="range" id="substrateSpeed" min="1" max="20" value="10" class="w-full h-1 bg-slate-700 rounded-lg appearance-none cursor-pointer">
                    </div>
                    <div class="bg-slate-950/50 p-3 rounded-lg border border-white/5">
                        <label for="decayRate" class="block mb-2 text-slate-200">Decaimiento: <span id="decayRateValue" class="text-white">0.0010</span></label>
                        <input type="range" id="decayRate" min="0" max="0.05" step="0.001" value="0.001" class="w-full h-1 bg-slate-700 rounded-lg appearance-none cursor-pointer">
                    </div>
                    <div class="flex items-center">
                        <button onclick="resetSimulation()" class="w-full py-3 bg-amber-600 hover:bg-amber-500 text-white font-bold uppercase tracking-widest text-[10px] rounded transition-colors shadow-lg shadow-amber-900/20">
                            Reiniciar
                        </button>
                    </div>
                </div>

                <!-- Canvas de Visualización -->
                <div id="visualization" class="w-full h-[50vh] min-h-[400px] rounded-lg relative overflow-hidden">
                    <!-- SVG insertado por D3 aquí -->
                </div>
            </section>

            <!-- 1. Fundamentos -->
            <section id="fundamentos" class="w-full mx-auto mb-20 text-left">
                <h2 class="text-3xl font-serif font-bold text-white mb-8 border-l-4 border-amber-500 pl-6">1. El Problema de la Definición Biológica</h2>
                <div class="prose prose-invert prose-lg max-w-none text-slate-300 leading-relaxed font-light text-justify">
                    <p>
                        La biología contemporánea ha tendido a enfatizar la genética y la evolución, confundiendo a menudo dos dominios distintos: los procesos que dependen de la historia (como la evolución y la filogénesis) y los procesos que dependen de la organización individual inmediata. Los autores postulan una tesis radical: la capacidad de reproducirse no es intrínseca a la definición fundamental de lo que es estar vivo.
                    </p>

                    <blockquote class="citation-modern">
                        Afirmamos que la reproducción y la evolución no son rasgos constitutivos de la organización viva [...] En contraste, afirmamos que la organización viva solo puede caracterizarse sin ambigüedades especificando la red de interacciones de componentes que constituyen un sistema vivo como un todo.
                        <span class="citation-source">Varela, Maturana & Uribe (1974), p. 187</span>
                    </blockquote>

                    <p>
                        Para entender lo vivo, no debemos preguntar qué propiedades hacen que un sistema se reproduzca, sino <strong>"¿cuál es la organización necesaria y suficiente para que un sistema dado sea una unidad viva?"</strong>, independientemente de su capacidad para dejar descendencia o su historia evolutiva.
                    </p>
                </div>
            </section>

            <!-- 2. Organización vs Estructura -->
            <section id="organizacion" class="w-full mx-auto mb-20 text-left">
                <h2 class="text-3xl font-serif font-bold text-white mb-8 border-l-4 border-amber-500 pl-6">2. Organización Autopoiética</h2>

                <div class="grid md:grid-cols-2 gap-8 mb-12">
                    <div class="concept-card border-l-2 border-l-amber-500">
                        <h3 class="text-amber-500 font-bold text-lg mb-2">Autopoiesis</h3>
                        <p class="text-sm leading-relaxed text-slate-300">
                            Sistemas cuya organización se mantiene invariante a través de un recambio constante de <span class="sim-text-substrate">componentes</span>. El producto de su operación es el propio sistema. Son autónomos en su esencia.
                        </p>
                    </div>
                    <div class="concept-card">
                        <h3 class="text-slate-400 font-bold text-lg mb-2">Alopoiesis</h3>
                        <p class="text-sm leading-relaxed text-slate-400">
                            Sistemas mecanísticos donde el producto de su operación es diferente del sistema mismo (como un ribosoma produciendo proteínas o una fábrica de autos). Su identidad depende del observador, no de su operación interna.
                        </p>
                    </div>
                </div>

                <div class="prose prose-invert prose-lg max-w-none text-slate-300 leading-relaxed font-light text-justify">
                    <p>
                        La definición formal presentada en el paper es rigurosa y recursiva. Un sistema autopoiético es aquel que produce sus propios <span class="sim-text-substrate">componentes</span>, los cuales a su vez regeneran la red que los produjo.
                    </p>

                    <blockquote class="citation-modern">
                        La organización autopoiética se define como una unidad por una red de producciones de componentes que (i) participan recursivamente en la misma red de producciones de componentes que produjo estos componentes, y (ii) realizan la red de producciones como una unidad en el espacio en el que existen los componentes.
                        <span class="citation-source">Varela, Maturana & Uribe (1974), p. 188</span>
                    </blockquote>

                    <p>
                        Esta fenomenología da lugar a la <strong>Autonomía</strong>. Mientras la red de producción de <span class="sim-text-link">enlaces</span> y <span class="sim-text-substrate">sustratos</span> no se interrumpa, el sistema compensa las perturbaciones externas y mantiene su identidad. Si la red se rompe, la unidad se desintegra (muerte).
                    </p>
                </div>
            </section>

            <!-- 3. El Modelo Computacional -->
            <section id="modelo" class="w-full mx-auto mb-20 text-left">
                <h2 class="text-3xl font-serif font-bold text-white mb-8 border-l-4 border-amber-500 pl-6">3. El Modelo Mínimo (Teselado)</h2>
                <div class="prose prose-invert prose-lg max-w-none text-slate-300 leading-relaxed font-light text-justify">
                    <p>
                        El paper presenta una encarnación simple de esta organización en un universo bidimensional, visualizado en la simulación superior. No es una simulación física realista, sino una abstracción lógica de la producción celular.
                    </p>

                    <h3 class="text-xl text-amber-500 font-bold mt-8 mb-4">Reglas de Interacción (Schema I)</h3>
                    <ul class="space-y-4 font-mono text-sm bg-slate-900/80 p-6 rounded-lg border border-slate-800 shadow-inner">
                        <li class="flex items-start">
                            <span class="text-amber-500 min-w-[140px] font-bold tracking-wider">[1. Composición]</span>
                            <span class="text-slate-300">
                                <span class="sim-text-enzyme">Catalizador (*)</span> + 2 <span class="sim-text-substrate">Sustratos (O)</span> &rarr; <span class="sim-text-link">Enlace (L)</span>
                            </span>
                        </li>
                        <li class="flex items-start">
                            <span class="text-amber-500 min-w-[140px] font-bold tracking-wider">[2. Concatenación]</span>
                            <span class="text-slate-300">
                                <span class="sim-text-link">Enlace (L)</span> + <span class="sim-text-link">Enlace (L)</span> &rarr; Cadena <span class="sim-text-link">(L-L)</span>
                            </span>
                        </li>
                        <li class="flex items-start">
                            <span class="text-amber-500 min-w-[140px] font-bold tracking-wider">[3. Desintegración]</span>
                            <span class="text-slate-300">
                                <span class="sim-text-link">Enlace (L)</span> &rarr; 2 <span class="sim-text-substrate">Sustratos (O)</span>
                            </span>
                        </li>
                    </ul>

                    <p class="mt-6">
                        La emergencia ocurre cuando una cadena de <span class="sim-text-link">enlaces (L)</span> se cierra sobre sí misma encerrando un <span class="sim-text-enzyme">catalizador (*)</span>. El catalizador, ahora "protegido" dentro de la membrana, tiene acceso a <span class="sim-text-substrate">sustratos (O)</span> que permean la membrana y produce nuevos <span class="sim-text-link">enlaces</span> que reparan las rupturas espontáneas.
                    </p>

                    <blockquote class="citation-modern">
                        La organización autopoiética es [...] la que por definición implica la realización de una unidad dinámica. Los mismos componentes pueden generar otras organizaciones alopoiéticas; por ejemplo, una cadena de enlaces es claramente alopoiética ya que la producción de los componentes que la realizan como unidad no entra en su definición como unidad.
                        <span class="citation-source">Varela, Maturana & Uribe (1974), p. 191</span>
                    </blockquote>
                </div>
            </section>

            <!-- 4. La Llave de 6 Puntos -->
            <section id="criterios" class="w-full mx-auto mb-20 text-left">
                <h2 class="text-3xl font-serif font-bold text-white mb-8 border-l-4 border-amber-500 pl-6">4. La Llave de 6 Puntos</h2>
                <div class="prose prose-invert prose-lg max-w-none text-slate-300 leading-relaxed font-light text-justify">
                    <p>
                        ¿Cómo determinamos si algo está vivo? Los autores proponen un algoritmo de decisión paso a paso para distinguir sistemas autopoiéticos de agregados físicos (como cristales) o sistemas alopoiéticos.
                    </p>

                    <div class="space-y-6 mt-8 bg-slate-900/30 p-8 rounded-xl border border-white/5">
                        <div class="flex gap-4 items-start">
                            <div class="text-4xl font-black text-slate-700 leading-none">1</div>
                            <div>
                                <strong class="text-slate-200 block mb-1">Identificación de Límites</strong>
                                <p class="text-sm text-slate-400">¿Tiene la unidad límites identificables mediante interacciones preferenciales? Si no, la entidad es indescriptible en este dominio.</p>
                            </div>
                        </div>
                        <div class="flex gap-4 items-start">
                            <div class="text-4xl font-black text-slate-700 leading-none">2</div>
                            <div>
                                <strong class="text-slate-200 block mb-1">Componentes Constitutivos</strong>
                                <p class="text-sm text-slate-400">¿Está compuesta por elementos constitutivos físicos? Si no, es un todo inanalizable abstracto.</p>
                            </div>
                        </div>
                        <div class="flex gap-4 items-start">
                            <div class="text-4xl font-black text-slate-700 leading-none">3</div>
                            <div>
                                <strong class="text-slate-200 block mb-1">Sistema Mecanístico</strong>
                                <p class="text-sm text-slate-400">¿Es un sistema donde las propiedades dependen de las relaciones entre componentes (leyes termodinámicas/físicas)? Si no, no es autopoiético.</p>
                            </div>
                        </div>
                        <div class="flex gap-4 items-start">
                            <div class="text-4xl font-black text-slate-700 leading-none">4</div>
                            <div>
                                <strong class="text-slate-200 block mb-1">Límites por Vecindad</strong>
                                <p class="text-sm text-slate-400">¿Los límites se constituyen por relaciones de vecindad preferencial determinadas por sus propiedades físicas (ej. tensión superficial, enlace químico)?</p>
                            </div>
                        </div>
                        <div class="flex gap-4 items-start">
                            <div class="text-4xl font-black text-slate-700 leading-none">5</div>
                            <div>
                                <strong class="text-slate-200 block mb-1">Producción Interna</strong>
                                <p class="text-sm text-slate-400">¿Son los componentes de los límites (<span class="sim-text-link">enlaces</span>) producidos por las interacciones dentro de la unidad?</p>
                            </div>
                        </div>
                        <div class="flex gap-4 items-start">
                            <div class="text-4xl font-black text-amber-500 leading-none">6</div>
                            <div>
                                <strong class="text-amber-500 block mb-1">Producción Recursiva (El Criterio Final)</strong>
                                <p class="text-sm text-slate-200">
                                    Si todos los demás componentes de la unidad (ej. <span class="sim-text-enzyme">catalizadores</span>) también son producidos por interacciones internas o participan permanentemente en ellas, entonces tienes una <strong>Unidad Autopoiética</strong>.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

        </main>
    </div>

    <!-- Script de Simulación (D3.js Logic) - MANTENIDO INTEGRO -->
    <script is:inline>
        document.addEventListener('DOMContentLoaded', function() {
            initAutopoiesisSimulation();
        });

        function initAutopoiesisSimulation() {
            const vizContainer = document.getElementById('visualization');
            if (!vizContainer) return;

            let width, height, cols, rows;
            const cellSize = 12; // Un poco más grande para mejor visibilidad
            const svg = d3.select("#visualization")
                .append("svg")
                .attr("width", "100%")
                .attr("height", "100%")
                .attr("preserveAspectRatio", "xMidYMid meet");

            let grid, substrates, enzymes, links;
            let substrateDensity = 0.5;
            let enzymeCount = 20;
            let substrateSpeed = 10;
            let decayRate = 0.001;
            let animationFrameId;

            // Mapeo de inputs
            d3.select("#substrateDensity").on("input", function() {
                substrateDensity = +this.value / 100;
                d3.select("#substrateDensityValue").text(this.value);
            });
            d3.select("#enzymeCount").on("input", function() {
                enzymeCount = +this.value;
                d3.select("#enzymeCountValue").text(enzymeCount);
            });
            d3.select("#substrateSpeed").on("input", function() {
                substrateSpeed = +this.value;
                d3.select("#substrateSpeedValue").text(substrateSpeed);
            });
            d3.select("#decayRate").on("input", function() {
                decayRate = +this.value;
                d3.select("#decayRateValue").text(decayRate.toFixed(4));
            });

            // Función global de reinicio
            window.resetSimulation = function() {
                if (animationFrameId) cancelAnimationFrame(animationFrameId);

                width = vizContainer.clientWidth;
                height = vizContainer.clientHeight;

                if (width < cellSize || height < cellSize) {
                    svg.selectAll("*").remove();
                    return;
                }

                cols = Math.floor(width / cellSize);
                rows = Math.floor(height / cellSize);
                svg.attr("viewBox", `0 0 ${width} ${height}`);

                grid = Array(cols).fill(null).map(() => Array(rows).fill(0));
                substrates = [];
                enzymes = [];
                links = [];

                // Inicializar Sustratos
                const substrateCount = Math.floor(cols * rows * substrateDensity);
                for (let i = 0; i < substrateCount; i++) {
                    let x, y;
                    do {
                        x = Math.floor(Math.random() * cols);
                        y = Math.floor(Math.random() * rows);
                    } while (grid[x][y] !== 0);
                    grid[x][y] = 1;
                    substrates.push({ x, y });
                }

                // Inicializar Enzimas
                for (let i = 0; i < enzymeCount; i++) {
                    let x, y;
                    do {
                        x = Math.floor(Math.random() * cols);
                        y = Math.floor(Math.random() * rows);
                    } while (grid[x][y] !== 0);
                    grid[x][y] = 2;
                    enzymes.push({ x, y });
                }
                animate();
            }

            function moveSubstrates() {
                substrates.forEach(s => {
                    if (Math.random() < substrateSpeed / 10) {
                        const dir = Math.floor(Math.random() * 4);
                        const newX = s.x + [1, 0, -1, 0][dir];
                        const newY = s.y + [0, 1, 0, -1][dir];
                        if (isValid(newX, newY) && grid[newX][newY] === 0) {
                            grid[s.x][s.y] = 0;
                            s.x = newX; s.y = newY;
                            grid[s.x][s.y] = 1;
                        }
                    }
                });
            }

            function interact() {
                enzymes.forEach(e => {
                    const neighbors = getNeighbors(e.x, e.y);
                    const substrateNeighbors = neighbors.filter(n => grid[n.x][n.y] === 1);
                    if (substrateNeighbors.length >= 2) {
                        const s1 = substrateNeighbors[0];
                        const s2 = substrateNeighbors[1];
                        grid[s1.x][s1.y] = 3;
                        grid[s2.x][s2.y] = 0;
                        // Remover sustratos de la lista de libres
                        substrates = substrates.filter(s => !(s.x === s1.x && s.y === s1.y) && !(s.x === s2.x && s.y === s2.y));
                        links.push({ x: s1.x, y: s1.y });
                    }
                });
                disintegrateLinks();
            }

            function disintegrateLinks() {
                links = links.filter(l => {
                    if (Math.random() < decayRate) {
                        grid[l.x][l.y] = 1;
                        substrates.push({ x: l.x, y: l.y });
                        return false;
                    }
                    return true;
                });
            }

            function updateVisualization() {
                const data = [
                    ...substrates.map(d => ({ type: "substrate", id: `s-${d.x}-${d.y}`, x: d.x, y: d.y })),
                    ...enzymes.map(d => ({ type: "enzyme", id: `e-${d.x}-${d.y}`, x: d.x, y: d.y })),
                    ...links.map(d => ({ type: "link", id: `l-${d.x}-${d.y}`, x: d.x, y: d.y }))
                ];

                const circles = svg.selectAll("circle").data(data, d => d.id);

                circles.exit().remove();

                circles.enter().append("circle")
                    .attr("r", cellSize / 2.5)
                    .attr("class", d => `circle-${d.type}`)
                    .attr("cx", d => d.x * cellSize + cellSize / 2)
                    .attr("cy", d => d.y * cellSize + cellSize / 2);

                circles
                    .attr("cx", d => d.x * cellSize + cellSize / 2)
                    .attr("cy", d => d.y * cellSize + cellSize / 2);

                d3.select("#status").text(`Sustratos: ${substrates.length} | Enlaces: ${links.length} | Enzimas: ${enzymes.length}`);
            }

            function getNeighbors(x, y) {
                const neighbors = [];
                for (let dx of [-1, 0, 1]) {
                    for (let dy of [-1, 0, 1]) {
                        if (dx === 0 && dy === 0) continue;
                        const nx = x + dx; const ny = y + dy;
                        if (isValid(nx, ny)) neighbors.push({ x: nx, y: ny });
                    }
                }
                return neighbors;
            }

            function isValid(x, y) {
                return x >= 0 && x < cols && y >= 0 && y < rows;
            }

            function animate() {
                moveSubstrates();
                interact();
                updateVisualization();
                animationFrameId = requestAnimationFrame(animate);
            }

            window.addEventListener("resize", resetSimulation);
            resetSimulation();
        }
    </script>

