---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteNav from "../components/SiteNav.astro";
---
<BaseLayout
  title="Vida, Mente y Cosmos | Juego de la Vida"
  description="Una exploración interactiva del autómata celular de John Conway: matemáticas, emergencia biológica y complejidad."
  htmlClass="scroll-smooth"
>
  <Fragment slot="head">
    <!-- TAILWIND & CONFIG (PLANTILLA MAESTRA) -->
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        serif: ['Merriweather', 'serif'],
                        mono: ['JetBrains Mono', 'monospace'],
                    },
                    colors: {
                        cosmos: { 950: '#020617', 900: '#08080c', 800: '#11111a', },
                        neon: { blue: '#4f46e5', green: '#10b981', purple: '#a855f7', cyan: '#06b6d4', gold: '#fbbf24' }
                    },
                    animation: {
                        'float': 'float 8s ease-in-out infinite',
                        'pulse-slow': 'pulse 6s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                        'spin-slow': 'spin 20s linear infinite',
                    },
                    keyframes: {
                        float: {
                            '0%, 100%': { transform: 'translateY(0)' },
                            '50%': { transform: 'translateY(-15px)' }
                        }
                    }
                }
            }
        }
    </script>

    <!-- FONTS & LIBS -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@200;300;400;600;900&family=Merriweather:ital,wght@0,300;0,400;1,400&family=JetBrains+Mono:wght@300&display=swap" rel="stylesheet">
    <script is:inline src="https://unpkg.com/lucide@latest"></script>
    <script is:inline src="https://d3js.org/d3.v7.min.js"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>

    <!-- MATHJAX FOR EQUATIONS -->
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/mathjax/2.7.5/MathJax.js?config=TeX-MML-AM_CHTML"></script>

    <style is:global>
        :root { --nav-height: 80px; --amber: #f59e0b; --dark: #0f172a; --slate-300: #cbd5e1; }
        body { font-family: 'Inter', sans-serif; background-color: var(--dark); color: var(--slate-300); line-height: 1.8; overflow-x: hidden; background-image: radial-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px); background-size: 40px 40px; text-align: justify; }

        .glass-card { background: rgba(17, 17, 26, 0.7); backdrop-filter: blur(16px); border: 1px solid rgba(255, 255, 255, 0.05); transition: all 0.5s; }
        .glass-card:hover { transform: translateY(-5px); background: rgba(26, 26, 46, 0.9); border-color: rgba(255, 255, 255, 0.1); box-shadow: 0 20px 50px -10px rgba(0,0,0,0.5); }

        /* Simulation Specific Styles */
        .visualization-container svg { cursor: crosshair; }
        .circle-live { fill: #06b6d4; filter: drop-shadow(0 0 4px #06b6d4); } /* Neon Cyan */

        /* MathJax Override for Dark Mode */
        .mjx-chtml { color: #e2e8f0 !important; outline: none; }
        .equation-box { background: rgba(255, 255, 255, 0.03); border-left: 3px solid #4f46e5; padding: 1.5rem; margin: 1.5rem 0; border-radius: 0 0.5rem 0.5rem 0; overflow-x: auto; }

        input[type=range] { -webkit-appearance: none; background: transparent; }
        input[type=range]::-webkit-slider-thumb { -webkit-appearance: none; height: 16px; width: 16px; border-radius: 50%; background: #06b6d4; cursor: pointer; margin-top: -6px; box-shadow: 0 0 10px #06b6d4; }
        input[type=range]::-webkit-slider-runnable-track { width: 100%; height: 4px; cursor: pointer; background: #334155; border-radius: 2px; }

        /* Custom Grid for wide layout */
        .bento-grid { display: grid; grid-template-columns: repeat(12, 1fr); gap: 1.5rem; }
    </style>
  </Fragment>

  <!-- BACKGROUND LAYERS -->
  <div class="bg-gradient" style="position: fixed; inset: 0; background: radial-gradient(circle at 30% 70%, rgba(6, 182, 212, 0.05) 0%, transparent 40%), var(--dark); z-index: -2;"></div>
  <canvas id="bg-canvas" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1;"></canvas>

  <SiteNav />

  <div class="main-content" style="padding-top: 80px; min-height: 100vh;">

      <!-- HERO SECTION -->
      <section class="relative pt-32 pb-20 px-6 overflow-hidden">
           <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-neon-cyan/5 rounded-full blur-[120px] -z-10"></div>

           <div class="max-w-7xl mx-auto text-center">
              <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-white/10 bg-white/5 backdrop-blur-sm mb-6 animate-float">
                  <span class="w-2 h-2 rounded-full bg-neon-cyan animate-pulse"></span>
                  <span class="text-[10px] font-mono text-neon-cyan tracking-widest uppercase">Complejidad & Matemáticas</span>
              </div>
              <h1 class="text-5xl md:text-8xl font-bold tracking-tighter mb-6 text-white">
                  <span class="text-transparent bg-clip-text bg-gradient-to-r from-white via-gray-200 to-gray-500">Juego de la Vida</span>
              </h1>
              <p class="text-lg md:text-2xl text-gray-400 font-serif italic max-w-3xl mx-auto leading-relaxed">
                  "Desde la simplicidad del código binario emerge la danza impredecible del universo."
              </p>
          </div>
      </section>

      <!-- MAIN CONTENT (MODIFICADO A 7XL) -->
      <section class="py-12 bg-black/30 border-t border-white/5">
          <div class="max-w-7xl mx-auto px-4 sm:px-6 space-y-8">

              <!-- SIMULATION CARD - FULL WIDTH -->
              <div class="glass-card rounded-2xl p-6 md:p-8">
                  <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 border-b border-white/10 pb-4 gap-4">
                      <div class="flex items-center gap-3">
                          <i data-lucide="cpu" class="text-neon-cyan w-6 h-6"></i>
                          <h2 class="text-2xl font-bold text-white">Laboratorio de Autómatas</h2>
                      </div>
                      <div class="flex items-center gap-4 text-xs md:text-sm font-mono bg-white/5 px-4 py-2 rounded-full border border-white/5">
                           <span class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-neon-green animate-pulse"></span> Sistema Activo</span>
                           <span class="text-gray-500">|</span>
                           <span id="status" class="text-neon-cyan">Generando...</span>
                      </div>
                  </div>

                  <!-- Visualization Area -->
                  <div id="visualization" class="w-full h-[500px] md:h-[600px] bg-cosmos-900 rounded-lg border border-white/10 shadow-[inset_0_0_20px_rgba(0,0,0,0.5)] mb-6 relative overflow-hidden cursor-crosshair">
                      <!-- D3 SVG will be appended here -->
                  </div>

                  <!-- Controls Dashboard -->
                  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 bg-cosmos-800/50 p-6 rounded-xl border border-white/5">

                      <!-- Col 1: Parameters -->
                      <div class="space-y-4">
                          <h3 class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Parámetros Iniciales</h3>
                          <div class="space-y-3">
                              <div>
                                  <div class="flex justify-between text-xs text-gray-400 font-mono mb-1">
                                      <label for="density">Entropía (Densidad)</label>
                                      <span id="densityValue" class="text-neon-cyan">30%</span>
                                  </div>
                                  <input type="range" id="density" min="5" max="60" value="30" class="w-full">
                              </div>
                              <div>
                                  <div class="flex justify-between text-xs text-gray-400 font-mono mb-1">
                                      <label for="speed">Frecuencia Temporal</label>
                                      <span id="speedValue" class="text-neon-cyan">100ms</span>
                                  </div>
                                  <input type="range" id="speed" min="10" max="1000" step="10" value="100" class="w-full">
                              </div>
                          </div>
                      </div>

                      <!-- Col 2: Info -->
                      <div class="flex flex-col justify-center items-center text-center border-y md:border-y-0 md:border-x border-white/5 py-4 md:py-0">
                          <i data-lucide="activity" class="text-gray-600 mb-2 w-5 h-5"></i>
                          <p class="text-sm text-gray-400 leading-tight">
                              Las reglas se aplican <span class="text-white font-bold">simultáneamente</span> a todas las células en cada paso discreto de tiempo.
                          </p>
                      </div>

                      <!-- Col 3: Actions -->
                      <div class="flex flex-col justify-center gap-3">
                          <button onclick="toggleSimulation()" id="playPauseBtn" class="w-full py-3 bg-neon-blue/10 hover:bg-neon-blue/20 border border-neon-blue/50 text-neon-blue rounded-lg text-sm font-bold transition-all flex items-center justify-center gap-2 hover:shadow-[0_0_15px_rgba(79,70,229,0.3)]">
                              <i data-lucide="pause" class="w-4 h-4"></i> Pausar Simulación
                          </button>
                          <button onclick="resetSimulation()" class="w-full py-3 bg-white/5 hover:bg-white/10 border border-white/10 text-gray-300 hover:text-white rounded-lg text-sm font-medium transition-colors flex items-center justify-center gap-2">
                              <i data-lucide="rotate-ccw" class="w-4 h-4"></i> Reiniciar Universo
                          </button>
                      </div>
                  </div>
              </div>

              <!-- SPLIT SECTION: Intro & Zoo -->
              <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

                  <!-- LEFT COLUMN (Introduction) -->
                  <div class="lg:col-span-7 space-y-8">
                      <div class="glass-card rounded-2xl p-8 h-full">
                          <h2 class="text-3xl font-bold text-white mb-6 flex items-center gap-3">
                              <span class="w-1 h-8 bg-neon-purple rounded-full"></span>
                              El Juego de Cero Jugadores
                          </h2>
                          <div class="prose prose-invert max-w-none text-gray-300 space-y-4">
                              <p>
                                  En 1970, el matemático británico <strong class="text-white">John Horton Conway</strong> presentó al mundo un sistema que desafió nuestra comprensión de la vida y el cómputo. Publicado en la columna de Martin Gardner en <em>Scientific American</em>, el <strong class="text-neon-purple">Juego de la Vida</strong> no es un juego donde se gana o se pierde, sino un espectador de la evolución.
                              </p>
                              <p>
                                  Es el ejemplo más famoso de un <span class="text-neon-cyan">autómata celular</span>. Sobre una rejilla infinita, cada celda vive o muere basándose únicamente en el estado de sus 8 vecinos inmediatos. No hay un dios central, no hay un plan maestro.
                              </p>
                              <p class="border-l-2 border-neon-purple pl-4 italic text-gray-400">
                                  "Me gusta pensar que si inyectaras las reglas del Juego de la Vida en una computadora lo suficientemente grande y esperaras un tiempo infinito... eventualmente verías formas de vida evolucionar." — John Conway
                              </p>
                          </div>
                      </div>
                  </div>

                  <!-- RIGHT COLUMN (Conway's Zoo) -->
                  <div class="lg:col-span-5 space-y-8">
                      <div class="glass-card rounded-2xl p-8 h-full bg-gradient-to-br from-cosmos-900 to-cosmos-800">
                          <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
                              <i data-lucide="grid-3x3" class="text-neon-green"></i>
                              El Zoológico de Patrones
                          </h2>
                          <p class="text-sm text-gray-400 mb-6">De la aleatoriedad surgen tres tipos fundamentales de "criaturas" matemáticas:</p>

                          <ul class="space-y-4">
                              <li class="bg-white/5 p-4 rounded-lg border border-white/5 hover:border-neon-green/30 transition-colors">
                                  <div class="flex items-center justify-between mb-2">
                                      <h4 class="font-bold text-neon-green">Vidas Estáticas</h4>
                                      <span class="text-xs bg-black/50 px-2 py-1 rounded text-gray-500">Periodo 1</span>
                                  </div>
                                  <p class="text-xs text-gray-400">Estructuras estables que no cambian, como el <strong>Bloque</strong> (2x2) o la <strong>Colmena</strong>.</p>
                              </li>
                              <li class="bg-white/5 p-4 rounded-lg border border-white/5 hover:border-neon-cyan/30 transition-colors">
                                  <div class="flex items-center justify-between mb-2">
                                      <h4 class="font-bold text-neon-cyan">Osciladores</h4>
                                      <span class="text-xs bg-black/50 px-2 py-1 rounded text-gray-500">Periodo N</span>
                                  </div>
                                  <p class="text-xs text-gray-400">Patrones que repiten un ciclo. El <strong>Parpadeador</strong> (línea de 3) oscila cada turno.</p>
                              </li>
                              <li class="bg-white/5 p-4 rounded-lg border border-white/5 hover:border-neon-purple/30 transition-colors">
                                  <div class="flex items-center justify-between mb-2">
                                      <h4 class="font-bold text-neon-purple">Naves Espaciales</h4>
                                      <span class="text-xs bg-black/50 px-2 py-1 rounded text-gray-500">Móviles</span>
                                  </div>
                                  <p class="text-xs text-gray-400">Estructuras que se desplazan por el universo. El famoso <strong>Glider</strong> (Planeador) viaja en diagonal.</p>
                              </li>
                          </ul>
                      </div>
                  </div>
              </div>

              <!-- SPLIT SECTION: Math & Biology -->
              <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

                  <!-- MATH RULES -->
                  <div class="glass-card rounded-2xl p-8">
                      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
                          <span class="w-1 h-8 bg-neon-blue rounded-full"></span>
                          Axiomas Matemáticos
                      </h2>
                      <p class="text-gray-300 mb-6 text-sm">
                          Sea \( S_t \) el estado en el tiempo \( t \) y \( N \) la suma de vecinos activos. La función de transición local \( f \) es determinista:
                      </p>

                      <div class="grid grid-cols-1 gap-4">
                          <div class="group p-4 rounded-lg bg-white/5 border border-white/5 hover:bg-neon-blue/5 transition-all">
                              <h3 class="text-neon-blue font-bold text-sm uppercase tracking-wider mb-2">1. Supervivencia (Estabilidad)</h3>
                              <div class="equation-box !my-0 !py-2 !bg-transparent !border-0 text-sm">
                                  \[ S_{'{'}t+1{'}'} = 1 \iff S_t = 1 \land N \in {'{'}2, 3{'}'} \]
                              </div>
                              <p class="text-xs text-gray-500 mt-2">Equilibrio perfecto: ni soledad ni aglomeración.</p>
                          </div>

                          <div class="group p-4 rounded-lg bg-white/5 border border-white/5 hover:bg-neon-purple/5 transition-all">
                              <h3 class="text-neon-purple font-bold text-sm uppercase tracking-wider mb-2">2. Nacimiento (Reproducción)</h3>
                              <div class="equation-box !my-0 !py-2 !bg-transparent !border-0 text-sm">
                                  \[ S_{'{'}t+1{'}'} = 1 \iff S_t = 0 \land N = 3 \]
                              </div>
                              <p class="text-xs text-gray-500 mt-2">La condición dorada para la generación de vida.</p>
                          </div>

                          <div class="group p-4 rounded-lg bg-white/5 border border-white/5 hover:bg-red-500/5 transition-all">
                              <h3 class="text-red-400 font-bold text-sm uppercase tracking-wider mb-2">3. Muerte (Entropía)</h3>
                              <div class="equation-box !my-0 !py-2 !bg-transparent !border-0 text-sm">
                                  \[ S_{'{'}t+1{'}'} = 0 \quad \text{'{'}en cualquier otro caso{'}'} \]
                              </div>
                          </div>
                      </div>
                  </div>

                  <!-- BIOLOGY & PHILOSOPHY -->
                  <div class="glass-card rounded-2xl p-8 border-t-4 border-neon-green flex flex-col justify-between">
                      <div>
                          <h2 class="text-2xl font-bold text-white mb-6">Filosofía de la Complejidad</h2>
                          <div class="space-y-6 text-gray-300">
                              <p>
                                  El Juego de la Vida demuestra visualmente el concepto de <strong class="text-white">Emergencia Fuerte</strong>. Propiedades macroscópicas (movimiento, reproducción, computación) surgen de componentes microscópicos que no poseen esas propiedades en absoluto.
                              </p>
                              <ul class="space-y-4">
                                  <li class="flex items-start gap-3">
                                      <i data-lucide="dna" class="text-neon-green shrink-0 mt-1"></i>
                                      <div>
                                          <h4 class="font-bold text-white text-sm">Analogía Biológica</h4>
                                          <p class="text-xs text-gray-400 mt-1">Al igual que las moléculas inertes forman células vivas, los píxeles inertes forman organismos digitales. Simula dinámicas de población y competencia por recursos.</p>
                                      </div>
                                  </li>
                                  <li class="flex items-start gap-3">
                                      <i data-lucide="hard-drive" class="text-neon-blue shrink-0 mt-1"></i>
                                      <div>
                                          <h4 class="font-bold text-white text-sm">Universalidad Computacional</h4>
                                          <p class="text-xs text-gray-400 mt-1">Este sistema es <strong>Turing Completo</strong>. Teóricamente, dentro de este juego se podría construir una computadora funcional que simule a su vez otro Juego de la Vida.</p>
                                      </div>
                                  </li>
                              </ul>
                          </div>
                      </div>
                      <div class="mt-8 pt-6 border-t border-white/10 text-center">
                          <p class="text-xs font-serif italic text-gray-500">"La complejidad no requiere reglas complejas, solo tiempo y espacio."</p>
                      </div>
                  </div>
              </div>

          </div>
      </section>

  </div>

  <!-- FOOTER (PLANTILLA MAESTRA) -->
  <footer class="border-t border-white/5 bg-cosmos-950 py-12 relative z-10">
      <div class="max-w-7xl mx-auto px-6 text-center">
          <h3 class="text-2xl font-serif text-white mb-4">O.C.V.M.</h3>
          <p class="text-gray-500 text-sm max-w-md mx-auto mb-8">
              Arquitectura digital para la exploración de los sistemas complejos, la mente humana y la inmensidad del cosmos.
          </p>
          <div class="text-xs text-gray-600 font-mono">
              &copy; 2025 PROYECTO VIDA, MENTE Y COSMOS.
          </div>
      </div>
  </footer>

  <!-- LOGIC SCRIPTS -->
  <script is:inline>
      // --- 1. ICONS & UI INIT ---
      lucide.createIcons();

      // --- 2. GAME OF LIFE LOGIC (ADAPTED FOR O.C.V.M.) ---
      let vizContainer, svg, width, height, cols, rows;
      const cellSize = 6; // EVEN SMALLER FOR HD LOOK
      let grid = [];
      let generation = 0;
      let density = 0.3;
      let speed = 100;
      let isRunning = true;
      let animationId = null;

      function initSimulation() {
          vizContainer = document.getElementById('visualization');
          if(!vizContainer) return;

          // Clear previous SVG if exists
          d3.select("#visualization svg").remove();

          width = vizContainer.clientWidth;
          height = vizContainer.clientHeight;
          cols = Math.floor(width / cellSize);
          rows = Math.floor(height / cellSize);

          svg = d3.select("#visualization")
              .append("svg")
              .attr("width", "100%")
              .attr("height", "100%")
              .attr("viewBox", `0 0 ${width} ${height}`)
              .style("background", "transparent");

          resetSimulation();
      }

      function createGrid() {
          grid = new Array(cols).fill(null).map(() => new Array(rows).fill(0));
          for (let x = 0; x < cols; x++) {
              for (let y = 0; y < rows; y++) {
                  grid[x][y] = Math.random() < density ? 1 : 0;
              }
          }
      }

      function countNeighbors(x, y) {
          let sum = 0;
          for (let i = -1; i < 2; i++) {
              for (let j = -1; j < 2; j++) {
                  let col = (x + i + cols) % cols;
                  let row = (y + j + rows) % rows;
                  sum += grid[col][row];
              }
          }
          sum -= grid[x][y];
          return sum;
      }

      function computeNextGeneration() {
          let next = new Array(cols).fill(null).map(() => new Array(rows).fill(0));
          let liveCount = 0;

          for (let x = 0; x < cols; x++) {
              for (let y = 0; y < rows; y++) {
                  let state = grid[x][y];
                  let neighbors = countNeighbors(x, y);

                  if (state === 0 && neighbors === 3) {
                      next[x][y] = 1;
                      liveCount++;
                  } else if (state === 1 && (neighbors < 2 || neighbors > 3)) {
                      next[x][y] = 0;
                  } else {
                      next[x][y] = state;
                      if(state === 1) liveCount++;
                  }
              }
          }
          grid = next;
          return liveCount;
      }

      function draw() {
          const liveCells = [];
          for (let x = 0; x < cols; x++) {
              for (let y = 0; y < rows; y++) {
                  if (grid[x][y] === 1) {
                      liveCells.push({ x: x * cellSize, y: y * cellSize });
                  }
              }
          }

          // Using D3 join pattern for better performance with many elements
          const rects = svg.selectAll("rect").data(liveCells);

          rects.exit().remove();

          rects.enter()
              .append("rect")
              .merge(rects)
              .attr("x", d => d.x)
              .attr("y", d => d.y)
              .attr("width", cellSize - 0.5)
              .attr("height", cellSize - 0.5)
              .attr("fill", "#06b6d4") // Neon Cyan
              .attr("opacity", 0.9);
      }

      function step() {
          const liveCount = computeNextGeneration();
          generation++;
          draw();
          document.getElementById('status').innerText = `Gen: ${generation} | Población: ${liveCount}`;
      }

      window.resetSimulation = function() {
          if (animationId) clearInterval(animationId);
          createGrid();
          generation = 0;
          draw();
          if (isRunning) {
              animationId = setInterval(step, speed);
              updateBtnState(true);
          }
      };

      window.toggleSimulation = function() {
          isRunning = !isRunning;
          updateBtnState(isRunning);
          if (isRunning) {
              animationId = setInterval(step, speed);
          } else {
              clearInterval(animationId);
          }
      };

      function updateBtnState(running) {
          const btn = document.getElementById('playPauseBtn');
          const icon = running ? 'pause' : 'play';
          const text = running ? 'Pausar Simulación' : 'Reanudar Simulación';
          btn.innerHTML = `<i data-lucide="${icon}" class="w-4 h-4"></i> ${text}`;
          lucide.createIcons();

          if(running) {
              btn.classList.add('bg-neon-blue/10', 'text-neon-blue', 'border-neon-blue/50');
              btn.classList.remove('bg-neon-green/10', 'text-neon-green', 'border-neon-green/50');
          } else {
              btn.classList.remove('bg-neon-blue/10', 'text-neon-blue', 'border-neon-blue/50');
              btn.classList.add('bg-neon-green/10', 'text-neon-green', 'border-neon-green/50');
          }
      }

      // Listeners
      document.getElementById('density').addEventListener('input', (e) => {
          density = e.target.value / 100;
          document.getElementById('densityValue').innerText = e.target.value + '%';
          resetSimulation();
      });

      document.getElementById('speed').addEventListener('input', (e) => {
          speed = Number(e.target.value);
          document.getElementById('speedValue').innerText = e.target.value + 'ms';
          if (isRunning) {
              clearInterval(animationId);
              animationId = setInterval(step, speed);
          }
      });

      // Resize handler with debounce
      let resizeTimer;
      window.addEventListener('resize', () => {
          clearTimeout(resizeTimer);
          resizeTimer = setTimeout(() => {
              initSimulation();
          }, 200);
      });

      // Init Logic
      initSimulation();


      // --- 3. THREE.JS BACKGROUND (PLANTILLA MAESTRA) ---
      const canvas = document.getElementById('bg-canvas');
      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
      const renderer = new THREE.WebGLRenderer({ canvas: canvas, alpha: true });

      renderer.setSize(window.innerWidth, window.innerHeight);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

      const particlesGeometry = new THREE.BufferGeometry();
      const particlesCount = 700;
      const posArray = new Float32Array(particlesCount * 3);

      for(let i = 0; i < particlesCount * 3; i++) {
          posArray[i] = (Math.random() - 0.5) * 20;
      }

      particlesGeometry.setAttribute('position', new THREE.BufferAttribute(posArray, 3));
      const material = new THREE.PointsMaterial({
          size: 0.02,
          color: 0x4f46e5, // Neon Blue
          transparent: true,
          opacity: 0.8,
      });

      const particlesMesh = new THREE.Points(particlesGeometry, material);
      scene.add(particlesMesh);
      camera.position.z = 3;

      // Mouse interaction
      let mouseX = 0;
      let mouseY = 0;

      document.addEventListener('mousemove', (event) => {
          mouseX = event.clientX / window.innerWidth - 0.5;
          mouseY = event.clientY / window.innerHeight - 0.5;
      });

      function animateBg() {
          requestAnimationFrame(animateBg);
          particlesMesh.rotation.y += 0.001;
          particlesMesh.rotation.x += 0.0005;

          // Subtle parallax
          particlesMesh.rotation.x += mouseY * 0.05;
          particlesMesh.rotation.y += mouseX * 0.05;

          renderer.render(scene, camera);
      }
      animateBg();

      window.addEventListener('resize', () => {
          camera.aspect = window.innerWidth / window.innerHeight;
          camera.updateProjectionMatrix();
          renderer.setSize(window.innerWidth, window.innerHeight);
      });
  </script>
</BaseLayout>
