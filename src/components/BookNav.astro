---
// Navegación entre capítulos del libro "El Principio Vida" (Hans Jonas).
// Se coloca al pie de cada capítulo: saltar al anterior/siguiente y volver
// al índice del libro. Usa <div role="navigation"> (NO <nav>) a propósito,
// para no heredar la regla global `nav { position:fixed; top:0 }` del SiteNav.
// Solo se listan los capítulos ya migrados; ampliar al migrar EPV10–12, etc.
const chapters = [
  { slug: "epv-prologo", label: "Prólogo" },
  { slug: "epv-01", label: "Cap. 1" },
  { slug: "epv-02", label: "Cap. 2" },
  { slug: "epv-03", label: "Cap. 3" },
  { slug: "epv-04", label: "Cap. 4" },
  { slug: "epv-05", label: "Cap. 5" },
  { slug: "epv-06", label: "Cap. 6" },
  { slug: "epv-07", label: "Cap. 7" },
  { slug: "epv-08", label: "Cap. 8" },
  { slug: "epv-09", label: "Cap. 9" },
];

const { current } = Astro.props;
const i = chapters.findIndex((c) => c.slug === current);
const prev = i > 0 ? chapters[i - 1] : null;
const next = i >= 0 && i < chapters.length - 1 ? chapters[i + 1] : null;
---

<div
  role="navigation"
  aria-label="Navegación entre capítulos del libro"
  class="w-full max-w-3xl mx-auto my-20 px-6 flex items-center justify-between gap-4 text-[11px] font-medium uppercase tracking-widest"
>
  {
    prev ? (
      <a
        href={prev.slug}
        class="flex-1 text-left text-slate-400 hover:text-amber-400 transition-colors no-underline"
      >
        <span class="block text-[9px] text-slate-600">← Anterior</span>
        {prev.label}
      </a>
    ) : (
      <span class="flex-1" />
    )
  }

  <a
    href="principio-vida"
    class="shrink-0 px-4 py-2 rounded-full border border-amber-500/30 text-amber-500 hover:bg-amber-500/10 transition-colors no-underline"
  >
    Índice del libro
  </a>

  {
    next ? (
      <a
        href={next.slug}
        class="flex-1 text-right text-slate-400 hover:text-amber-400 transition-colors no-underline"
      >
        <span class="block text-[9px] text-slate-600">Siguiente →</span>
        {next.label}
      </a>
    ) : (
      <span class="flex-1" />
    )
  }
</div>
